from scipy.stats import fisher_exact

def fisher_binary(df, exposure, outcome="CRC_status"):
    table = pd.crosstab(df[exposure], df[outcome])
    table = table.reindex(index=[0, 1], columns=[0, 1], fill_value=0)
    or_val, p_val = fisher_exact(table)
    return table, or_val, p_val

for exposure in [
    "has_crc_pathogenic_variant",
    "has_lynch_variant",
    "has_apc_variant",
    "has_mutyh_variant"
]:
