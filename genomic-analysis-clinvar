import statsmodels.api as sm
import numpy as np
import pandas as pd

model_df = case_control_df.dropna(subset=[
    "CRC_status",
    "has_crc_pathogenic_variant",
    "deprivation_quartile",
    "sex_at_birth",
    "race_clean",
    "no_health_insurance"
]).copy()

X = pd.get_dummies(
    model_df[[
        "has_crc_pathogenic_variant",
        "deprivation_quartile",
        "sex_at_birth",
        "race_clean",
        "no_health_insurance"
    ]],
    drop_first=True
)

X = X.apply(pd.to_numeric, errors="coerce")

for col in X.columns:
    if X[col].dtype == bool:
        X[col] = X[col].astype(int)

X = sm.add_constant(X)
y = pd.to_numeric(model_df["CRC_status"], errors="coerce")

valid_idx = X.dropna().index.intersection(y.dropna().index)
X = X.loc[valid_idx]
y = y.loc[valid_idx]

print("Model size:", X.shape, y.shape)

model_genetic = sm.Logit(y, X).fit()
print(model_genetic.summary())

or_table_genetic = pd.DataFrame({
    "Odds Ratio": np.exp(model_genetic.params),
    "CI Lower": np.exp(model_genetic.conf_int()[0]),
    "CI Upper": np.exp(model_genetic.conf_int()[1]),
    "p_value": model_genetic.pvalues
})

