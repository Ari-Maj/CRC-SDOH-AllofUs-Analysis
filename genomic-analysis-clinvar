import pandas as pd
import numpy as np
import plotly.express as px

# total group sizes
n_controls = 14512
n_cases = 3629

immune_counts = pd.DataFrame({
    "Variant": ["Immune panel", "TLR4", "TNF", "STAT3"],
    "Controls": [530, 454, 78, 3],
    "CRC Cases": [152, 133, 19, 0]
})

# convert to long format
immune_long = immune_counts.melt(
    id_vars="Variant",
    value_vars=["Controls", "CRC Cases"],
    var_name="Group",
    value_name="Count"
)

# add total N
immune_long["Total"] = immune_long["Group"].map({
    "Controls": n_controls,
    "CRC Cases": n_cases
})

# calculate proportions
immune_long["Proportion"] = immune_long["Count"] / immune_long["Total"]

# calculate standard error
immune_long["SE"] = np.sqrt(
    immune_long["Proportion"] * (1 - immune_long["Proportion"]) / immune_long["Total"]
)

# 95% CI
immune_long["CI"] = 1.96 * immune_long["SE"]

# plot proportions instead of raw counts
fig = px.bar(
    immune_long,
    x="Variant",
    y="Proportion",
    color="Group",
    barmode="group",
    text=immune_long["Count"],  # keep counts on bars
    title="Figure 4. Frequency of immune-related variant carriers by CRC status",
    labels={"Proportion": "Proportion of participants"}
)

# add error bars
fig.update_traces(
    error_y=dict(
        type="data",
        array=immune_long["CI"],
        visible=True
    ),
    textposition="outside"
)

fig.update_layout(width=950, height=550)
fig.show()

