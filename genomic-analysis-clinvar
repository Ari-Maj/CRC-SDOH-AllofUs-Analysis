import pandas as pd
import plotly.graph_objects as go
from scipy.stats import chi2_contingency, ttest_ind

df = case_control_df.copy()

cases = df[df["CRC_status"] == 1]
controls = df[df["CRC_status"] == 0]

rows = []

def add_cat(var, categories=None, label=None):
    temp = df[[var, "CRC_status"]].dropna().copy()
    if categories is None:
        categories = temp[var].unique()

    ct = pd.crosstab(temp[var], temp["CRC_status"])
    p = chi2_contingency(ct)[1] if ct.shape[0] > 1 else None

    rows.append([label if label else var, "", "", f"{p:.3g}" if p is not None else ""])
    for cat in categories:
        case_n = (cases[var] == cat).sum()
        ctrl_n = (controls[var] == cat).sum()
        rows.append([
            f"  {cat}",
            f"{case_n} ({case_n/len(cases)*100:.1f}%)",
            f"{ctrl_n} ({ctrl_n/len(controls)*100:.1f}%)",
            ""
        ])

def add_cont(var, label=None):
    c1 = cases[var].dropna()
    c0 = controls[var].dropna()
    p = ttest_ind(c1, c0, equal_var=False).pvalue if len(c1) and len(c0) else None
    rows.append([
        label if label else var,
        f"{c1.mean():.2f} ± {c1.std():.2f}",
        f"{c0.mean():.2f} ± {c0.std():.2f}",
        f"{p:.3g}" if p is not None else ""
    ])

add_cont("match_age", "Matched age, mean ± SD")
add_cat("sex_at_birth", ["Female", "Male", "Other"], "Sex, n (%)")
add_cat("race_clean", ["White", "Black or African American", "Other/Unknown"], "Race, n (%)")
add_cat("deprivation_quartile", ["Q1", "Q2", "Q3", "Q4_highest"], "Deprivation quartile, n (%)")

if "has_crc_pathogenic_variant" in df.columns:
    temp = df.copy()
    temp["has_crc_pathogenic_variant"] = temp["has_crc_pathogenic_variant"].map({0: "No", 1: "Yes"})
    cases2 = temp[temp["CRC_status"] == 1]
    controls2 = temp[temp["CRC_status"] == 0]
    ct = pd.crosstab(temp["has_crc_pathogenic_variant"], temp["CRC_status"])
    p = chi2_contingency(ct)[1]
    rows.append(["Pathogenic CRC variant, n (%)", "", "", f"{p:.3g}"])
    for cat in ["Yes", "No"]:
        case_n = (cases2["has_crc_pathogenic_variant"] == cat).sum()
        ctrl_n = (controls2["has_crc_pathogenic_variant"] == cat).sum()
        rows.append([
            f"  {cat}",
            f"{case_n} ({case_n/len(cases2)*100:.1f}%)",
            f"{ctrl_n} ({ctrl_n/len(controls2)*100:.1f}%)",
            ""
        ])

table1_df = pd.DataFrame(rows, columns=["Variable", "CRC Cases", "Controls", "P value"])

fig = go.Figure(data=[go.Table(
    header=dict(values=list(table1_df.columns), align="left"),
    cells=dict(values=[table1_df[c] for c in table1_df.columns], align="left")
)])

fig.update_layout(
    title="Table 1. Cohort characteristics of colorectal cancer cases and matched controls",
    width=1100,
    height=900
)

fig.show()

